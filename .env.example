# Copy to .env and fill in local values. Never commit real secrets.

# Runtime
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Database (async SQLAlchemy URL; use asyncpg driver for PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/app_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# OpenAI
OPENAI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1
MAX_DAILY_COST_USD=10.0
MAX_PER_CV_COST_USD=0.15

# Routing thresholds (mirrors n8n workflow policy)
SHORTLIST_THRESHOLD=80
REVIEW_THRESHOLD=50

# CORS: comma-separated origins; leave empty for server-to-server only
CORS_ALLOW_ORIGINS=http://localhost:3000
